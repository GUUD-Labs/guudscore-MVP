import { useEffect } from 'react';

import { createFileRoute, useSearch } from '@tanstack/react-router';

import { tokenStorage } from '@/hooks/use-auth';

export const Route = createFileRoute('/auth/callback/twitter')({
  component: TwitterCallback,
});

function TwitterCallback() {
  const search = useSearch({ from: '/auth/callback/twitter' });

  useEffect(() => {
    const accessToken = search.accessToken as string | undefined;
    const refreshToken = search.refreshToken as string | undefined;

    console.log('[Twitter Callback] URL parameters:', {
      hasAccessToken: !!accessToken,
      hasRefreshToken: !!refreshToken,
      accessTokenLength: accessToken?.length,
      refreshTokenLength: refreshToken?.length,
      search: search,
    });

    if (accessToken && refreshToken) {
      console.log('[Twitter Callback] Setting tokens...');

      try {
        // Check if localStorage is available
        if (typeof window !== 'undefined' && window.localStorage) {
          console.log('[Twitter Callback] localStorage is available');

          // Use tokenStorage.setTokens with default expiresIn of 24 hours
          tokenStorage.setTokens({
            accessToken,
            refreshToken,
            expiresIn: 86400, // 24 hours in seconds
          });

          // Verify tokens were set
          const storedAccessToken = localStorage.getItem('accessToken');
          const storedRefreshToken = localStorage.getItem('refreshToken');

          console.log('[Twitter Callback] Tokens verification:', {
            accessTokenSet: !!storedAccessToken,
            refreshTokenSet: !!storedRefreshToken,
            accessTokenMatch: storedAccessToken === accessToken,
            refreshTokenMatch: storedRefreshToken === refreshToken,
          });

          if (storedAccessToken && storedRefreshToken) {
            console.log(
              '[Twitter Callback] Tokens set successfully, redirecting to dashboard...'
            );

            // Redirect to dashboard
            window.location.href = '/dashboard';
          } else {
            console.error(
              '[Twitter Callback] Tokens were not saved to localStorage!'
            );
            window.location.href = '/login?error=storage_failed';
          }
        } else {
          console.error('[Twitter Callback] localStorage is not available!');
          window.location.href = '/login?error=no_storage';
        }
      } catch (error) {
        console.error('[Twitter Callback] Error setting tokens:', error);
        window.location.href = '/login?error=exception';
      }
    } else {
      console.error('[Twitter Callback] Missing tokens:', {
        hasAccessToken: !!accessToken,
        hasRefreshToken: !!refreshToken,
      });

      // Redirect to login
      window.location.href = '/login?error=missing_tokens';
    }
  }, [search]);

  return (
    <div className="flex min-h-screen items-center justify-center">
      <div className="text-center">
        <div className="mx-auto mb-4 h-12 w-12 animate-spin rounded-full border-b-2 border-blue-500"></div>
        <p className="text-gray-600 dark:text-gray-400">Giriş yapılıyor...</p>
      </div>
    </div>
  );
}
